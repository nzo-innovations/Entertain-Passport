# ============================================================
# nZO Ticketing - environment template (Supabase)
# Copy to .env and fill in the values from your Supabase dashboard.
# ============================================================

# Pooled connection (PgBouncer, port 6543) - runtime.
# connection_limit=5 allows parallel page queries in dev; use 1 per serverless instance in prod if needed.
DATABASE_URL="postgresql://postgres.fxoyitlauwbcdcwqrwge:nZOtickets2026@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Direct connection (port 5432) - migrations.
DIRECT_URL="postgresql://postgres.fxoyitlauwbcdcwqrwge:nZOtickets2026@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# Supabase Auth / client (public)
NEXT_PUBLIC_SUPABASE_URL="https://fxoyitlauwbcdcwqrwge.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx_or_anon_key"

# Branding
NEXT_PUBLIC_APP_NAME="Entertain Passport"
NEXT_PUBLIC_APP_TAGLINE="The most powerful passport granting visa-free access to unforgettable experiences."
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Server-only: required for the organizer Team feature to create gate-staff
# accounts (Supabase Auth admin API). Find it in Supabase Dashboard ->
# Project Settings -> API -> service_role key. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================================
# VERIFICATION PLANE (B2B card-validation product) - ISOLATED
# ============================================================
# Dedicated Supabase project (separate from core). Prod ref: vzvxphcdcmahwwgadrlp
# Region: ap-south-1 (Mumbai) - match core for sync/edge latency.
# Dashboard: https://vzvxphcdcmahwwgadrlp.supabase.co
# DO NOT point these at the core DATABASE_URL - verify:guard will refuse db:push:verify.
# Pooled (runtime, port 6543):
VERIFY_DATABASE_URL="postgresql://postgres.vzvxphcdcmahwwgadrlp:[VERIFY-DB-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=20&sslmode=require"
# Direct (migrations, port 5432):
VERIFY_DIRECT_URL="postgresql://postgres.vzvxphcdcmahwwgadrlp:[VERIFY-DB-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Master key custody for DESFire/on-card envelope encryption + rotation.
# provider: "local" (dev) | "aws-kms" | "vault" (prod). LOCAL key = base64(32 bytes).
VERIFY_KMS_PROVIDER="local"
VERIFY_KMS_KEY_ID="ep-card-master"
VERIFY_LOCAL_MASTER_KEY=""

# Server-side pepper for PII/UID hashing in the verification plane (store in KMS in prod).
VERIFY_HASH_PEPPER=""

# Tolerated clock skew (seconds) on partner HMAC request timestamps.
VERIFY_HMAC_MAX_SKEW_SECONDS="120"

# ============================================================
# NFC PASSPORT TAG SIGNING (core app - never expose to client)
# ============================================================
# HMAC-SHA256 secret for on-tag identity signatures. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NFC_HMAC_KEY_VERSION="1"
NFC_HMAC_SECRET=""
# Rotated keys: NFC_HMAC_SECRET_V2, NFC_HMAC_SECRET_V3, ...

# Pepper for hashing user NIC/Passport at assignment (never store plain ID).
PASSPORT_ID_HASH_PEPPER=""

# Server-only pepper for deriving RR/RRRR/XXX serial segments (HMAC-SHA512). Falls back to PASSPORT_ID_HASH_PEPPER.
PASSPORT_SERIAL_PEPPER=""

# ============================================================
# GOOGLE WALLET (virtual Entertain Passport)
# ============================================================
# Create a Google Pay & Wallet Console issuer account, enable Google Wallet API,
# create a Generic pass class, and a service account with Wallet Object Issuer role.
# GOOGLE_WALLET_ISSUER_ID: numeric issuer ID from Google Wallet console
# GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL: service account client email
# GOOGLE_WALLET_PRIVATE_KEY: PEM private key (use \n for newlines in .env)
# GOOGLE_WALLET_CLASS_SUFFIX: pass class suffix (class id = {issuerId}.{suffix})
GOOGLE_WALLET_ISSUER_ID=""
GOOGLE_WALLET_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_WALLET_PRIVATE_KEY=""
GOOGLE_WALLET_CLASS_SUFFIX="entertain_passport"
