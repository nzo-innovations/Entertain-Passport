# ============================================================
# nZO Ticketing — environment template (Supabase)
# Copy to .env and fill in the values from your Supabase dashboard.
# ============================================================

# Pooled connection (PgBouncer, port 6543) — runtime.
# connection_limit=5 allows parallel page queries in dev; use 1 per serverless instance in prod if needed.
DATABASE_URL="postgresql://postgres.fxoyitlauwbcdcwqrwge:nZOtickets2026@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"

# Direct connection (port 5432) — migrations.
DIRECT_URL="postgresql://postgres.fxoyitlauwbcdcwqrwge:nZOtickets2026@aws-1-ap-south-1.pooler.supabase.com:5432/postgres"

# Supabase Auth / client (public)
NEXT_PUBLIC_SUPABASE_URL="https://fxoyitlauwbcdcwqrwge.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx_or_anon_key"

# Branding
NEXT_PUBLIC_APP_NAME="Entertain Passport"
NEXT_PUBLIC_APP_TAGLINE="Your passport to every event."
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Server-only: required for the organizer Team feature to create gate-staff
# accounts (Supabase Auth admin API). Find it in Supabase Dashboard ->
# Project Settings -> API -> service_role key. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# ============================================================
# VERIFICATION PLANE (B2B card-validation product) — ISOLATED
# ============================================================
# isolation = SEPARATE DATABASE · cards = DESFire EV2/EV3 · modes = TAP-ONLY
# A DEDICATED database/Supabase project with NO access to core sales data.
# The DB role in these URLs must have NO privileges on the core `public` schema.
VERIFY_DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
VERIFY_DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# Master key custody for DESFire/on-card envelope encryption + rotation.
# provider: "local" (dev) | "aws-kms" | "vault" (prod). LOCAL key = base64(32 bytes).
VERIFY_KMS_PROVIDER="local"
VERIFY_KMS_KEY_ID="ep-card-master"
VERIFY_LOCAL_MASTER_KEY=""

# Server-side pepper for PII/UID hashing in the verification plane (store in KMS in prod).
VERIFY_HASH_PEPPER=""

# Tolerated clock skew (seconds) on partner HMAC request timestamps.
VERIFY_HMAC_MAX_SKEW_SECONDS="120"
