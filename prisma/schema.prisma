// Entertain Passport - Prisma schema
// Database: Supabase PostgreSQL.
// DATABASE_URL  -> pooled connection (PgBouncer, port 6543) used at runtime.
// DIRECT_URL    -> direct connection (port 5432) used for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ----- Auth & Users -----------------------------------------------------------

// Profile row. `id` mirrors Supabase auth.users.id (uuid as text).
// Rows are created automatically by the on_auth_user_created trigger.
model User {
  id            String   @id // == auth.users.id
  email         String   @unique
  phone         String?  @unique
  firstName     String?
  lastName      String?
  nic           String?  @unique // Legacy NIC mirror; set only when idType = NIC.
  name          String?
  avatarUrl     String?
  role          String   @default("CUSTOMER") // CUSTOMER | SUPER_ADMIN | ORGANIZER | ARTIST_MANAGER | ARTIST | BUSINESS_OWNER | GATE_STAFF
  loyaltyPoints Int      @default(0)

  // Optional profile details. Collected after signup (skippable) and required
  // to unlock loyalty rewards & offers (see profileIsComplete()).
  gender        String?   // MALE | FEMALE | OTHER | PREFER_NOT_TO_SAY
  birthday      DateTime?
  idType        String?  @default("NIC") // Primary identity type: NIC or PASSPORT.
  idNumber      String?  @unique // Primary customer identity number; nullable unique for legacy/admin users.

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  addresses          Address[]
  orders             Order[]
  loyaltyLedger      LoyaltyEntry[]
  cart               Cart?
  auditLogs          AuditLog[]
  ownedOrganizations Organization[]       @relation("OrgOwner")
  orgMemberships     OrganizationMember[]
  eventStaff         EventStaff[]
  reviewedEvents     Event[]              @relation("EventReviewer")
  approvalActions    EventApprovalLog[]
  checkIns           Ticket[]             @relation("TicketChecker")
  heldTickets        Ticket[]             @relation("TicketHolder")
  passports          RfidCard[]           @relation("UserPassports")
  programmedCards    RfidCard[]           @relation("PassportProgrammer")
  passportCardOrders PassportCardOrder[]
  soldPhysicalTickets PhysicalTicket[]    @relation("PhysicalTicketSeller")
  loyaltyOffersCreated LoyaltyOffer[]     @relation("LoyaltyOfferCreator")
  loyaltyOfferGrants   LoyaltyOfferGrant[] @relation("LoyaltyOfferGrantUser")
  loyaltyGrantsIssued  LoyaltyOfferGrant[] @relation("LoyaltyOfferGranter")
  fulfilledPassportOrders PassportCardOrder[] @relation("PassportOrderFulfiller")
  gateScans            GateScan[]           @relation("GateScanOperator")
  passportBatchesGenerated PassportBatch[]  @relation("PassportBatchGenerator")
  passportInventoryAssigned PassportNumberInventory[] @relation("PassportInventoryAssignee")
  nfcProgrammingDone   NfcCardProgramming[] @relation("NfcCardProgrammer")
  nfcProgrammingAsUser NfcCardProgramming[] @relation("NfcProgrammingUser")
  seatHolds            SeatHold[]
}

model Address {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1    String
  line2    String?
  city     String  // town / city
  district String?
  province String?
  state    String?
  country  String  @default("Sri Lanka")
  zip      String?
  isPrimary Boolean @default(true)
}

// ----- Organizations (Organizer / Artist Manager / Business Owner) --------------

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  type        String   // ORGANIZER | ARTIST_MANAGER | BUSINESS_OWNER (same portal access)
  description String?
  logoUrl     String?
  website     String?
  phone       String?
  isVerified  Boolean  @default(false)
  // Per-organization commission override set by Super Admin. When null the
  // platform default (PlatformSettings.defaultCommissionPct) applies.
  commissionPct Float?
  // Company / venue owners: Places to Go registration selections.
  placesMainCategoryId String?
  placesMainCategory   Category? @relation("OrgPlacesMain", fields: [placesMainCategoryId], references: [id], onDelete: SetNull)
  placesSubCategoryId  String?
  placesSubCategory    Category? @relation("OrgPlacesSub", fields: [placesSubCategoryId], references: [id], onDelete: SetNull)
  accessShows          Boolean   @default(true)
  accessPlaces         Boolean   @default(false)
  tags                 OrganizationTag[]
  ownerId     String
  owner       User     @relation("OrgOwner", fields: [ownerId], references: [id])
  members     OrganizationMember[]
  events      Event[]
  artistEvents EventArtist[] @relation("ArtistEvents")
  venues      Venue[]          @relation("OrgVenues")
  layoutTemplates VenueLayoutTemplate[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       // OWNER | ADMIN | WORKER (org-level; event staff is separate)
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

// ----- Catalog ----------------------------------------------------------------

// Hierarchical taxonomy for Discover & Shows and Places to Go.
// parentId null = main category; non-null = subcategory under that main.
model Category {
  id        String     @id @default(cuid())
  module    String     @default("SHOWS") // SHOWS | PLACES
  name      String
  slug      String
  iconKey   String?
  imageUrl  String?
  sortOrder Int        @default(0)
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  events    Event[]
  venuesMain Venue[]   @relation("VenuePlacesMain")
  venuesSub  Venue[]   @relation("VenuePlacesSub")
  orgsMain   Organization[] @relation("OrgPlacesMain")
  orgsSub    Organization[] @relation("OrgPlacesSub")
  createdAt DateTime   @default(now())

  @@unique([module, slug])
  @@index([module, parentId, sortOrder])
}

// Reusable labels for both modules (multi-select on events, venues, org signup).
model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  sortOrder   Int      @default(0)
  modulesJson String   @default("[\"SHOWS\",\"PLACES\"]")
  createdAt   DateTime @default(now())
  events      EventTag[]
  venues      VenueTag[]
  orgs        OrganizationTag[]
}

model EventTag {
  eventId String
  tagId   String
  event   Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([eventId, tagId])
  @@index([tagId])
}

model VenueTag {
  venueId String
  tagId   String
  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([venueId, tagId])
  @@index([tagId])
}

model OrganizationTag {
  organizationId String
  tagId          String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([organizationId, tagId])
}

model Venue {
  id          String      @id @default(cuid())
  name        String
  slug        String?     @unique
  description String?
  kind        String?     // PUB | RESTAURANT | CLUB | LOUNGE | OTHER
  address     String      // address line 1
  line2       String?     // address line 2
  city        String      // town / city
  district    String?
  province    String?
  country     String      @default("Sri Lanka")
  mapUrl      String?     // optional Google Maps location link
  lat         Float?
  lng         Float?
  capacity    Int         @default(0)
  hasSeating  Boolean     @default(false)
  layoutJson  String?
  coverImageUrl String?
  phone       String?
  website     String?
  openingHoursJson String?
  isPublished Boolean     @default(false)
  organizationId String?
  organization   Organization? @relation("OrgVenues", fields: [organizationId], references: [id], onDelete: SetNull)
  placesMainCategoryId String?
  placesMainCategory   Category? @relation("VenuePlacesMain", fields: [placesMainCategoryId], references: [id], onDelete: SetNull)
  placesSubCategoryId  String?
  placesSubCategory    Category? @relation("VenuePlacesSub", fields: [placesSubCategoryId], references: [id], onDelete: SetNull)
  tags        VenueTag[]
  events      Event[]
  seatPrices  SeatPrice[]
  programs    VenueProgram[]
  posts       VenuePost[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @default(now()) @updatedAt

  @@index([isPublished, organizationId])
  @@index([kind, city])
}

// Non-ticketed weekly or one-off happenings at a venue (live bands, DJ nights, etc.).
model VenueProgram {
  id            String   @id @default(cuid())
  venueId       String
  venue         Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  performerName String?
  actType       String   // SOLO | TRIO | FULL_BAND | DJ | OTHER
  recurrence    String   // WEEKLY | ONE_OFF
  dayOfWeek     Int?     // 0=Sun … 6=Sat when recurrence=WEEKLY
  specificDate  DateTime?
  startTime     String   // HH:mm
  endTime       String?
  isPublished   Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([venueId, dayOfWeek])
}

// Partner news, articles and updates for a published place listing.
model VenuePost {
  id          String   @id @default(cuid())
  venueId     String
  venue       Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  title       String
  body        String
  imageUrl    String?
  detailLink  String?
  publishedAt DateTime @default(now())
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([venueId, publishedAt])
  @@index([isPublished, publishedAt])
}

model SeatPrice {
  id      String @id @default(cuid())
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  section String
  tier    String
  price   Int
}

model Event {
  id                 String   @id @default(cuid())
  title              String
  slug               String   @unique
  shortDescription   String?
  description        String
  status             String   @default("DRAFT") // DRAFT | PUBLISHED | SOLD_OUT | CANCELLED | ENDED
  approvalStatus     String   @default("DRAFT") // DRAFT | PENDING_REVIEW | APPROVED | REJECTED | CHANGES_REQUESTED
  startsAt           DateTime
  endsAt             DateTime
  doorsOpenAt        DateTime?
  termsAndConditions String?
  socialLinksJson    String?
  currency           String   @default("LKR")
  commissionPct      Float    @default(5) // editable only by Super Admin
  salesThreshold     Int?
  featured           Boolean  @default(false)

  // ----- Physical (printed) ticket management -----
  // When enabled, every ticket category must have a matching number of
  // physical ticket reference codes before the event can be published.
  physicalTicketsEnabled Boolean @default(false)
  physicalCodeLength     Int?    // fixed length of each printed ref code
  physicalCodeCharset    String  @default("NUMERIC") // NUMERIC | ALPHANUMERIC
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewNote         String?
  reviewedById       String?
  reviewedBy         User?    @relation("EventReviewer", fields: [reviewedById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id])

  primaryImageId String?     @unique
  primaryImage   EventImage? @relation("PrimaryImage", fields: [primaryImageId], references: [id])

  images         EventImage[]       @relation("EventImages")
  packages       TicketPackage[]
  partners       EventPartner[]
  orderItems     OrderItem[]
  alerts         AdminAlert[]
  staff          EventStaff[]
  approvalLogs   EventApprovalLog[]
  artists        EventArtist[]
  physicalTickets PhysicalTicket[]
  tags           EventTag[]
  gateScans      GateScan[]
  eventSeatMap   EventSeatMap?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, approvalStatus, startsAt])
  @@index([status, approvalStatus, featured])
  @@index([categoryId])
  @@index([organizationId])
}

model EventApprovalLog {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  fromStatus String
  toStatus   String
  note       String?
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  createdAt  DateTime @default(now())
}

model EventStaff {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String   // SCANNER | DOOR_MANAGER | EVENT_MANAGER
  isBillable Boolean  @default(false) // true when beyond 2 free staff per event
  createdAt  DateTime @default(now())

  @@unique([eventId, userId])
}

model EventImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  eventId   String?
  event     Event?  @relation("EventImages", fields: [eventId], references: [id], onDelete: Cascade)
  primaryOf Event?  @relation("PrimaryImage")
}

model EventPartner {
  id      String  @id @default(cuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name    String
  logoUrl String?
  link    String?
  tier    String?
}

model TicketPackage {
  id          String      @id @default(cuid())
  eventId     String
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Int
  qtyTotal    Int
  qtySold     Int         @default(0)
  /// SEATED = pick seats on map · STANDING = GA standing area · GENERAL = no seat pick
  ticketKind  String      @default("GENERAL")
  perksJson   String?
  sortOrder   Int         @default(0)
  cartItems   CartItem[]
  orderItems  OrderItem[]
  physicalTickets PhysicalTicket[]

  @@index([eventId])
}

// ----- Physical (printed) tickets ---------------------------------------------
// Inventory of pre-printed ticket reference codes. One row per printed code,
// owned by a ticket category (TicketPackage). Sold offline via an explicit
// manual action by an organizer, gate staff member, or Super Admin.
model PhysicalTicket {
  id         String        @id @default(cuid())
  eventId    String
  event      Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  packageId  String
  package    TicketPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  refCode    String        // printed reference code (unique within the event)
  status     String        @default("AVAILABLE") // AVAILABLE | SOLD | VOID
  soldAt     DateTime?
  soldById   String?
  soldBy     User?         @relation("PhysicalTicketSeller", fields: [soldById], references: [id], onDelete: SetNull)
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([eventId, refCode])
  @@index([packageId, status])
  @@index([eventId, status])
}

// ----- Seating layouts & reserved seats ---------------------------------------

model VenueLayoutTemplate {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  description    String?
  layoutJson     String
  isSystem       Boolean  @default(false)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  eventSeatMaps  EventSeatMap[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isSystem])
}

model EventSeatMap {
  id              String   @id @default(cuid())
  eventId         String   @unique
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  templateId      String?
  template        VenueLayoutTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  layoutJson      String
  seatingEnabled  Boolean  @default(false)
  published       Boolean  @default(false)
  publishedAt     DateTime?
  categories      SeatCategory[]
  seats           Seat[]
  holds           SeatHold[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SeatCategory {
  id               String       @id @default(cuid())
  eventSeatMapId   String
  eventSeatMap     EventSeatMap @relation(fields: [eventSeatMapId], references: [id], onDelete: Cascade)
  externalId       String
  name             String
  color            String
  price            Int
  enabled          Boolean      @default(true)
  packageId        String?
  sortOrder        Int          @default(0)

  @@unique([eventSeatMapId, externalId])
}

model Seat {
  id                 String       @id @default(cuid())
  eventSeatMapId     String
  eventSeatMap       EventSeatMap @relation(fields: [eventSeatMapId], references: [id], onDelete: Cascade)
  externalId         String
  sectionId          String?
  tableId            String?
  label              String
  rowIndex           Int?
  colIndex           Int?
  categoryExternalId String?
  status             String       @default("AVAILABLE") // AVAILABLE | HELD | SOLD | BLOCKED
  enabled            Boolean      @default(true)
  ticket             Ticket?

  @@unique([eventSeatMapId, externalId])
  @@index([eventSeatMapId, status])
}

model SeatHold {
  id             String       @id @default(cuid())
  eventSeatMapId String
  eventSeatMap   EventSeatMap @relation(fields: [eventSeatMapId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  seatIdsJson    String
  heldAt         DateTime     @default(now())
  idleReleaseAt  DateTime?
  expiresAt      DateTime
  maxExpiresAt   DateTime
  phase          String       @default("SELECTING") // SELECTING | CHECKOUT | IDLE

  @@index([eventSeatMapId, userId])
  @@index([expiresAt])
  @@index([maxExpiresAt])
}

// ----- Cart & Orders ----------------------------------------------------------

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    String     @default("ACTIVE")
  items     CartItem[]
  expiresAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String        @id @default(cuid())
  cartId    String
  cart      Cart          @relation(fields: [cartId], references: [id], onDelete: Cascade)
  packageId String
  package   TicketPackage @relation(fields: [packageId], references: [id])
  qty       Int
  seatIds   String?
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  status        String      @default("PENDING")
  subtotal      Int
  fees          Int
  passportCardTotal Int @default(0)
  commissionAmt Int
  total         Int
  currency      String      @default("LKR")
  paymentRef    String?
  loyaltyEarned Int         @default(0)
  loyaltySpent  Int         @default(0)
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId, createdAt(sort: Desc)])
}

model OrderItem {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event         @relation(fields: [eventId], references: [id])
  packageId String
  package   TicketPackage @relation(fields: [packageId], references: [id])
  qty       Int
  unitPrice Int
  seatIds   String?
  tickets   Ticket[]
}

model Ticket {
  id           String    @id @default(cuid())
  orderItemId  String
  orderItem    OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  barcode      String    @unique // internal unique code (legacy; we check in via NFC now)
  qrCode       String    @unique // legacy alias / full payload token
  // Human-friendly / printed identifier an organizer can set & print on a ticket
  // so gate staff can check in by typing it. Optional and unique when present.
  ticketCode   String?   @unique
  status       String    @default("VALID") // VALID | CHECKED_IN | REFUNDED | CANCELLED
  checkedInAt  DateTime?
  checkedInById String?
  checkedInBy  User?     @relation("TicketChecker", fields: [checkedInById], references: [id])

  // NFC "Entertain Passport" linked to this ticket (tap to check in).
  rfidCardId   String?
  rfidCard     RfidCard? @relation(fields: [rfidCardId], references: [id], onDelete: SetNull)

  // The actual attendee for this ticket. Bulk buyers with a passport can assign
  // each ticket to a friend by their account, NIC or passport number.
  holderUserId String?
  holder       User?     @relation("TicketHolder", fields: [holderUserId], references: [id], onDelete: SetNull)
  holderName   String?
  holderNic    String?

  seatId       String?   @unique
  seat         Seat?     @relation(fields: [seatId], references: [id], onDelete: SetNull)

  createdAt    DateTime  @default(now())

  @@index([rfidCardId])
  @@index([holderUserId])
  @@index([seatId])
}

// ----- NFC "Entertain Passport" cards ------------------------------------

model RfidCard {
  id             String    @id @default(cuid())
  passportId     String?   @unique // secure 128-bit UUID v4 identity token
  uid            String    @unique // raw NFC chip UID programmed by Super Admin
  passportNo     String    @unique // human-friendly Entertain Passport number
  label          String?
  status         String    @default("UNASSIGNED") // UNASSIGNED | ACTIVE | BLOCKED | LOST
  keyVersion     Int       @default(1)
  issuedAt       DateTime  @default(now())
  counter        Int       @default(0)
  signature      String?   // HMAC-SHA256 of tag payload (stored for audit; secret never on card beyond sig)
  assignedUserId String?
  assignedUser   User?     @relation("UserPassports", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt     DateTime?
  programmedById String?
  programmedBy   User?     @relation("PassportProgrammer", fields: [programmedById], references: [id], onDelete: SetNull)
  replacedByCardId String? @unique
  replacedByCard   RfidCard? @relation("CardReplacement", fields: [replacedByCardId], references: [id], onDelete: SetNull)
  replacesCard     RfidCard? @relation("CardReplacement")
  passportCardOrderId String?
  passportCardOrder   PassportCardOrder? @relation(fields: [passportCardOrderId], references: [id], onDelete: SetNull)
  inventoryId         String?            @unique
  inventory           PassportNumberInventory? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)
  walletCredentials   PassportWalletCredential[]
  tickets        Ticket[]
  offerGrants    LoyaltyOfferGrant[]
  gateScans      GateScan[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([assignedUserId])
  @@index([assignedUserId, status])
  @@index([status])
}

model PassportCardOrder {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quantity            Int      @default(1)
  unitPrice           Int
  total               Int
  currency            String   @default("LKR")
  paymentTiming       String   // PAY_NOW | DEFER_TO_NEXT_ORDER
  status              String   @default("REQUESTED") // PENDING_PAYMENT | PAID | DEFERRED | FULFILLED | CANCELLED | REQUESTED
  shippingMethod      String   @default("SL_REGISTERED_POST")
  shippingName        String?
  shippingPhone       String?
  addressId           String?
  addressSnapshotJson String?
  paymentRef          String?
  fulfilledAt         DateTime?
  fulfilledById       String?
  fulfilledBy         User?    @relation("PassportOrderFulfiller", fields: [fulfilledById], references: [id], onDelete: SetNull)
  rfidCards           RfidCard[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

// ----- Public passport number inventory (print backlog) -----------------------

model PassportBatch {
  id            String   @id @default(cuid())
  batchCode     String   @unique
  cardType      String   // 11 Standard | 21 VIP | 31 Platinum | 41 Artist | 51 Staff | 61 Partner
  quantity      Int
  issueYear     Int      // 2-digit year e.g. 26 for 2026
  status        String   @default("GENERATED") // GENERATED | EXPORTED | COMPLETE
  generatedById String?
  generatedBy   User?    @relation("PassportBatchGenerator", fields: [generatedById], references: [id], onDelete: SetNull)
  inventory     PassportNumberInventory[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([issueYear, cardType])
}

model PassportNumberInventory {
  id                      String   @id @default(cuid())
  publicPassportNumber    String   @unique // 16 digits, no spaces
  formattedPassportNumber String   // 8826 1101 4837 2914
  internalPassportUuid    String   @unique @default(uuid())
  cardType                String
  issueYear               Int
  status                  String   @default("GENERATED")
  // GENERATED | PRINTED | AVAILABLE | ASSIGNED | PROGRAMMED | BLOCKED | DAMAGED | REPLACED
  batchId                 String?
  batch                   PassportBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  assignedUserId          String?
  assignedUser            User?    @relation("PassportInventoryAssignee", fields: [assignedUserId], references: [id], onDelete: SetNull)
  assignedAt              DateTime?
  userPrimaryIdType       String?  // NIC | PASSPORT
  userPrimaryIdHash       String?  // HMAC hash - never plain ID
  programmedAt            DateTime?
  rfidCard                RfidCard?
  nfcProgramming          NfcCardProgramming[]
  walletCredentials       PassportWalletCredential[]
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([status, cardType])
  @@index([batchId])
  @@index([assignedUserId])
}

model NfcCardProgramming {
  id                   String   @id @default(cuid())
  inventoryId          String
  inventory            PassportNumberInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  publicPassportNumber String
  internalPassportUuid String
  userId               String?
  user                 User?    @relation("NfcProgrammingUser", fields: [userId], references: [id], onDelete: SetNull)
  userPrimaryIdType    String?
  userPrimaryIdHash    String?
  nfcUid               String
  keyVersion           Int      @default(1)
  counter              Int      @default(0)
  signature            String?
  programmingStatus    String   @default("PENDING") // PENDING | PROGRAMMED | FAILED | REPLACED
  programmedById       String?
  programmedBy         User?    @relation("NfcCardProgrammer", fields: [programmedById], references: [id], onDelete: SetNull)
  programmedAt         DateTime?
  createdAt            DateTime @default(now())

  @@index([inventoryId, createdAt(sort: Desc)])
  @@index([internalPassportUuid])
  @@index([nfcUid])
  @@index([programmingStatus])
}

// Virtual Entertain Passport credentials (Google Wallet, Apple Wallet, etc.)
model PassportWalletCredential {
  id                 String   @id @default(cuid())
  inventoryId        String
  inventory          PassportNumberInventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  rfidCardId         String?
  rfidCard           RfidCard? @relation(fields: [rfidCardId], references: [id], onDelete: SetNull)
  platform           String   // GOOGLE | APPLE
  credentialUid      String   @unique // VW… virtual UID bound into HMAC signature
  keyVersion         Int      @default(1)
  counter            Int      @default(0)
  signature          String
  issuedAt           DateTime @default(now())
  externalObjectId   String?
  smartTapRedemptionValue String? @unique // NFC Smart Tap token (gate lookup, no QR)
  status             String   @default("ACTIVE") // ACTIVE | REVOKED
  provisionedAt      DateTime @default(now())
  lastSyncedAt       DateTime?
  revokedAt          DateTime?

  @@unique([inventoryId, platform])
  @@index([rfidCardId])
  @@index([credentialUid, status])
}

// ----- Artist tagging on events ----------------------------------------------

model EventArtist {
  id             String       @id @default(cuid())
  eventId        String
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation("ArtistEvents", fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([eventId, organizationId])
  @@index([organizationId])
}

// ----- Loyalty ----------------------------------------------------------------

model LoyaltyEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  refId     String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}

// Super-Admin managed member offer (bonus points, perks, targeted campaigns).
model LoyaltyOffer {
  id          String    @id @default(cuid())
  title       String
  description String?
  kind        String    @default("GRANT_POINTS") // GRANT_POINTS | PERK
  pointsGrant Int       @default(0)
  pointCost   Int?
  status      String    @default("DRAFT") // DRAFT | ACTIVE | PAUSED | ENDED

  startsAt DateTime?
  endsAt   DateTime?

  // ALL_CARDS = every active passport holder; FILTERED = must match usage/points rules.
  audienceMode String @default("ALL_CARDS")

  minTotalUsage    Int?
  maxTotalUsage    Int?
  minLoyaltyPoints Int?
  maxLoyaltyPoints Int?
  passportNosJson  String? // JSON string[] - optional explicit allow-list

  maxTotalGrants   Int?
  maxGrantsPerUser Int? @default(1)
  grantsCount      Int  @default(0)

  createdById String?
  createdBy   User?    @relation("LoyaltyOfferCreator", fields: [createdById], references: [id], onDelete: SetNull)
  grants      LoyaltyOfferGrant[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, startsAt])
}

model LoyaltyOfferGrant {
  id            String      @id @default(cuid())
  offerId       String
  offer         LoyaltyOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation("LoyaltyOfferGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  rfidCardId    String?
  rfidCard      RfidCard?   @relation(fields: [rfidCardId], references: [id], onDelete: SetNull)
  pointsGranted Int         @default(0)
  note          String?
  grantedById   String?
  grantedBy     User?       @relation("LoyaltyOfferGranter", fields: [grantedById], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())

  @@index([offerId, createdAt(sort: Desc)])
  @@index([userId, offerId])
}

// ----- Admin / Ops ------------------------------------------------------------

model AdminAlert {
  id             String    @id @default(cuid())
  eventId        String
  event          Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  thresholdType  String
  thresholdValue Int
  channel        String    @default("email")
  lastFiredAt    DateTime?
  createdAt      DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String
  entity    String
  entityId  String
  diffJson  String?
  createdAt DateTime @default(now())
}

// HMAC key version registry (secrets live in env / KMS - never stored in DB).
model NfcKeyVersion {
  id        String   @id @default(cuid())
  version   Int      @unique
  label     String   @default("default")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Immutable gate / NFC scan audit trail.
model GateScan {
  id             String    @id @default(cuid())
  eventId        String?
  event          Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  rfidCardId     String?
  rfidCard       RfidCard? @relation(fields: [rfidCardId], references: [id], onDelete: SetNull)
  passportId     String
  cardUid        String
  counter        Int
  verdict        String    // ALLOW | DENY
  reason         String
  scanType       String    // REGISTER | VERIFY | CHECK_IN
  signatureValid Boolean?
  scannedById    String?
  scannedBy      User?     @relation("GateScanOperator", fields: [scannedById], references: [id], onDelete: SetNull)
  payloadJson    String?
  createdAt      DateTime  @default(now())

  @@index([eventId, createdAt(sort: Desc)])
  @@index([rfidCardId, createdAt(sort: Desc)])
  @@index([verdict, createdAt(sort: Desc)])
  @@index([passportId])
  @@index([scanType, createdAt(sort: Desc)])
}

model PlatformSettings {
  id                    String @id @default("default")
  defaultCommissionPct  Float  @default(5)
  freeStaffPerEvent     Int    @default(2)
  extraStaffMonthlyFee  Int    @default(1500) // cents per extra staff slot
  passportCardPrice     Int    @default(50000) // minor units; default LKR 500

  // Loyalty earn rules (Super-Admin controlled).
  loyaltyEnabled           Boolean @default(true)
  loyaltyRequiresPassport  Boolean @default(true)
  loyaltyMinorPerPoint     Int     @default(10000) // minor units spent per 1 point (LKR 100)

  updatedAt             DateTime @updatedAt
}
